<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Butterfly Particle - Curl Noise & Lines</title>
<style>
  body { margin: 0; overflow: hidden; background: radial-gradient(circle at center, #0a0a1a 0%, #000 100%); }
  canvas { display: block; }
  #info {
    position: absolute; top: 10px; left: 10px;
    color: #00ffcc; font-family: monospace; font-size: 11px;
    background: rgba(0,0,0,0.8); padding: 12px; border-radius: 5px;
    pointer-events: none; line-height: 1.5; z-index: 100;
  }
</style>
</head>
<body>
<div id="info">Loading...</div>

<script type="importmap">
{
  "imports": {
    "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
    "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
  }
}
</script>

<script type="module">
import * as THREE from 'three';
import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

const scene = new THREE.Scene();
scene.background = new THREE.Color(0x050510);
const camera = new THREE.PerspectiveCamera(40, window.innerWidth/window.innerHeight, 0.1, 2000);
camera.position.set(-1, 100, 0);

const renderer = new THREE.WebGLRenderer({antialias:true});
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
document.body.appendChild(renderer.domElement);
const controls = new OrbitControls(camera, renderer.domElement);
controls.enableDamping = true;

// ============ 严格使用你的最新参数 ============
let CONFIG_POINT_SIZE = 1; 
const CONFIG_MODEL_SCALE = 1;
const LIFETIME = 1.5;        
const MIN_SPEED = 0.01;       
const MAX_SPEED = 4.0;      
const NOISE_SCALE = 0.02;    
const NOISE_STRENGTH = 4.0;  

const MAX_LINE_COUNT = 4000; // 连线数量配额
// ===========================================

const clock = new THREE.Clock();
let particleSystem, lineSystem, mixer;
let skinnedMeshes = [];
const uniforms = { uTime: { value: 0 }, uPointSize: { value: CONFIG_POINT_SIZE } };
const tempVertex = new THREE.Vector3();

// --- Shader (含噪声) ---
const vertexShader = `
uniform float uPointSize;
uniform float uTime;
attribute vec3 aModelPos; 
attribute float aSeed;   
varying vec3 vColor;
varying float vAlpha;

float hash(float n) { return fract(sin(n) * 43758.5453123); }
vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
vec4 mod289(vec4 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
vec4 permute(vec4 x) { return mod289(((x*34.0)+1.0)*x); }
vec4 taylorInvSqrt(vec4 r) { return 1.79284291400159 - 0.85373472095314 * r; }
float snoise(vec3 v) {
  const vec2 C = vec2(1.0/6.0, 1.0/3.0);
  const vec4 D = vec4(0.0, 0.5, 1.0, 2.0);
  vec3 i = floor(v + dot(v, C.yyy));
  vec3 x0 = v - i + dot(i, C.xxx);
  vec3 g = step(x0.yzx, x0.xyz); vec3 l = 1.0 - g;
  vec3 i1 = min(g.xyz, l.zxy); vec3 i2 = max(g.xyz, l.zxy);
  vec3 x1 = x0 - i1 + C.xxx; vec3 x2 = x0 - i2 + C.yyy; vec3 x3 = x0 - D.yyy;
  i = mod289(i);
  vec4 p = permute(permute(permute(i.z+vec4(0.0, i1.z, i2.z, 1.0))+i.y+vec4(0.0, i1.y, i2.y, 1.0))+i.x+vec4(0.0, i1.x, i2.x, 1.0));
  vec4 j = p - 49.0 * floor(p * (1.0/49.0));
  vec4 x_ = floor(j * (1.0/7.0)); vec4 y_ = floor(j - 7.0 * x_);
  vec4 x = x_ * (1.0/7.0) + 0.5/7.0; vec4 y = y_ * (1.0/7.0) + 0.5/7.0;
  vec4 h = 1.0 - abs(x) - abs(y);
  vec4 b0 = vec4(x.xy, y.xy); vec4 b1 = vec4(x.zw, y.zw);
  vec4 s0 = floor(b0)*2.0 + 1.0; vec4 s1 = floor(b1)*2.0 + 1.0;
  vec4 sh = -step(h, vec4(0.0));
  vec4 a0 = b0.xzyw + s0.xzyw*sh.xxyy; vec4 a1 = b1.xzyw + s1.xzyw*sh.zzww;
  vec3 p0 = vec3(a0.xy, h.x); vec3 p1 = vec3(a0.zw, h.y); vec3 p2 = vec3(a1.xy, h.z); vec3 p3 = vec3(a1.zw, h.w);
  vec4 norm = taylorInvSqrt(vec4(dot(p0,p0), dot(p1,p1), dot(p2, p2), dot(p3,p3)));
  p0 *= norm.x; p1 *= norm.y; p2 *= norm.z; p3 *= norm.w;
  vec4 m = max(0.6 - vec4(dot(x0,x0), dot(x1,x1), dot(x2,x2), dot(x3,x3)), 0.0);
  return 42.0 * dot(m*m*m*m, vec4(dot(p0,x0), dot(p1,x1), dot(p2,x2), dot(p3,x3)));
}

void main(){
    float localTime = mod(uTime + aSeed * ${LIFETIME.toFixed(1)}, ${LIFETIME.toFixed(1)});
    float lifeRatio = localTime / ${LIFETIME.toFixed(1)};
    vec3 pos = aModelPos;
    float side = sign(aModelPos.z);
    float speed = mix(${MIN_SPEED.toFixed(2)}, ${MAX_SPEED.toFixed(2)}, hash(aSeed));
    pos.z += side * speed * localTime;
    
    // Curl Noise 位移
    float nx = snoise(pos * ${NOISE_SCALE.toFixed(3)} + uTime * 0.2);
    float ny = snoise(pos * ${NOISE_SCALE.toFixed(3)} + uTime * 0.2 + 10.0);
    float nz = snoise(pos * ${NOISE_SCALE.toFixed(3)} + uTime * 0.2 + 20.0);
    pos += vec3(nx, ny, nz) * ${NOISE_STRENGTH.toFixed(2)} * lifeRatio;

    vAlpha = smoothstep(0.0, 0.1, lifeRatio) * smoothstep(1.0, 0.7, lifeRatio);
    vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
    gl_PointSize = uPointSize * (300.0 / -mvPosition.z);
    gl_Position = projectionMatrix * mvPosition;
    vColor = mix(vec3(0.0, 0.9, 1.0), vec3(0.1, 0.3, 1.0), lifeRatio);
}
`;

const fragmentShader = `
varying vec3 vColor;
varying float vAlpha;
void main(){
    float d = length(gl_PointCoord - vec2(0.5));
    if(d > 0.5) discard;
    gl_FragColor = vec4(vColor, (1.0 - d*2.0) * vAlpha * 0.8);
}
`;

// --- 简易噪声 JS 实现 (用于同步连线位置，性能考虑使用简化版) ---
function simpleNoise(x, y, z) {
    return Math.sin(x) * Math.cos(y) * Math.sin(z); 
}

const glbURL = 'https://cdn.jsdelivr.net/gh/SihuiXu/Sihui-Model@main/hudiedie-jianmian3.glb';
new GLTFLoader().load(glbURL, gltf => {
    const model = gltf.scene;
    model.scale.set(CONFIG_MODEL_SCALE, CONFIG_MODEL_SCALE, CONFIG_MODEL_SCALE);
    mixer = new THREE.AnimationMixer(model);
    gltf.animations.forEach(clip => mixer.clipAction(clip).play());

    const modelVertices = [];
    model.traverse(child => {
        if(child.isSkinnedMesh || child.isMesh){
            skinnedMeshes.push(child);
            for(let i=0; i<child.geometry.attributes.position.count; i++) modelVertices.push(0,0,0);
        }
    });

    const totalCount = modelVertices.length / 3;
    const seeds = new Float32Array(totalCount);
    for(let i=0; i<totalCount; i++) seeds[i] = Math.random();

    const geometry = new THREE.BufferGeometry();
    geometry.setAttribute('position', new THREE.Float32BufferAttribute(modelVertices, 3));
    geometry.setAttribute('aModelPos', new THREE.Float32BufferAttribute(modelVertices, 3));
    geometry.setAttribute('aSeed', new THREE.BufferAttribute(seeds, 1));

    particleSystem = new THREE.Points(geometry, new THREE.ShaderMaterial({
        uniforms, vertexShader, fragmentShader, transparent:true, blending:THREE.AdditiveBlending, depthWrite:false
    }));
    scene.add(particleSystem);

    lineSystem = new THREE.LineSegments(
        new THREE.BufferGeometry().setAttribute('position', new THREE.BufferAttribute(new Float32Array(MAX_LINE_COUNT*6), 3)),
        new THREE.LineBasicMaterial({ color: 0x00ffff, transparent: true, opacity: 0.1, depthWrite:false })
    );
    scene.add(lineSystem);
    document.getElementById('info').innerHTML = "Curl Flow & Lines Active";
});

function updateAnimationSource() {
    if (!particleSystem || skinnedMeshes.length === 0) return;
    const modelAttr = particleSystem.geometry.attributes.aModelPos;
    const posAttr = particleSystem.geometry.attributes.position;
    const seedAttr = particleSystem.geometry.attributes.aSeed;
    const time = clock.elapsedTime;
    let index = 0;

    skinnedMeshes.forEach(mesh => {
        const p = mesh.geometry.attributes.position;
        if (mesh.isSkinnedMesh) mesh.skeleton.update();
        mesh.updateMatrixWorld();
        for (let i = 0; i < p.count; i++) {
            tempVertex.fromBufferAttribute(p, i);
            if (mesh.isSkinnedMesh) mesh.boneTransform(i, tempVertex);
            tempVertex.applyMatrix4(mesh.matrixWorld);
            
            // 基础模型坐标
            modelAttr.array[index*3] = tempVertex.x;
            modelAttr.array[index*3+1] = tempVertex.y;
            modelAttr.array[index*3+2] = tempVertex.z;

            // --- 在 JS 端模拟 Shader 位移逻辑，供连线系统使用 ---
            const seed = seedAttr.array[index];
            const localTime = (time + seed * LIFETIME) % LIFETIME;
            const lifeRatio = localTime / LIFETIME;
            const side = tempVertex.z >= 0 ? 1 : -1;
            const speed = MIN_SPEED + (MAX_SPEED - MIN_SPEED) * (seed % 1); // 简易随机速度

            let mx = tempVertex.x;
            let my = tempVertex.y;
            let mz = tempVertex.z + side * speed * localTime;

            // 模拟 Curl Noise 的微扰动 (简化版提高性能)
            const ns = NOISE_SCALE;
            const st = NOISE_STRENGTH * lifeRatio;
            mx += simpleNoise(mx * ns, my * ns, time * 0.2) * st;
            my += simpleNoise(my * ns, mz * ns, time * 0.2) * st;
            mz += simpleNoise(mz * ns, mx * ns, time * 0.2) * st;

            posAttr.array[index*3] = mx;
            posAttr.array[index*3+1] = my;
            posAttr.array[index*3+2] = mz;
            index++;
        }
    });
    modelAttr.needsUpdate = true;
    posAttr.needsUpdate = true;
}

function updateLines() {
    if (!lineSystem || !lineSystem.visible || !particleSystem) return;
    const pos = particleSystem.geometry.attributes.position.array;
    const linePos = lineSystem.geometry.attributes.position.array;
    let idx = 0;
    const count = pos.length / 3;
    const attempts = MAX_LINE_COUNT * 2; 

    for (let k = 0; k < attempts; k++) {
        if (idx >= MAX_LINE_COUNT * 6) break;
        const i = Math.floor(Math.random() * count);
        const j = Math.floor(Math.random() * count);
        if (i === j) continue;
        const dx = pos[i*3] - pos[j*3];
        const dy = pos[i*3+1] - pos[j*3+1];
        const dz = pos[i*3+2] - pos[j*3+2];
        const dSq = dx*dx + dy*dy + dz*dz;
        
        // 连线距离判定 (根据你的发散程度，这里设为 8.0)
        if (dSq < 64.0 && dSq > 0.5) {
            linePos[idx++] = pos[i*3]; linePos[idx++] = pos[i*3+1]; linePos[idx++] = pos[i*3+2];
            linePos[idx++] = pos[j*3]; linePos[idx++] = pos[j*3+1]; linePos[idx++] = pos[j*3+2];
        }
    }
    for (let m = idx; m < linePos.length; m++) linePos[m] = 0;
    lineSystem.geometry.attributes.position.needsUpdate = true;
}

function animate() {
    requestAnimationFrame(animate);
    const delta = clock.getDelta();
    if (mixer) mixer.update(delta);
    uniforms.uTime.value = clock.elapsedTime;
    updateAnimationSource(); 
    updateLines();
    controls.update();
    renderer.render(scene, camera);
}
animate();

window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
});
</script>
</body>
</html>
